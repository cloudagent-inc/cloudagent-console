{
  "name": "@cloudagent/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local-first CloudAgent desktop app suite.",
  "scripts": {
    "dev:ui": "cd .. && npm run dev:desktop-ui",
    "build:ui": "cd .. && npm run build:desktop-ui",
