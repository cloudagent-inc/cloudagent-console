# Optional developer override. If unset, Electron uses the packaged API entry.
# CLOUDAGENT_BACKEND_ENTRY=cloudagent-desktop/apps/api/src/index.mjs

# Optional. If unset, Electron stores local data under the app userData folder.
# CLOUDAGENT_LOCAL_DATA_DIR=/tmp/cloudagent-local-test

# Configure OpenAI and other provider keys from CloudAgent Console Preferences.

# Optional.
# CLOUDAGENT_OPEN_DEVTOOLS=1
# CLOUDAGENT_LOCAL_MCP_ENABLED=true
